---
const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<nav class="nav">
  <a href="/" class="brand">ConvertAllLocal</a>
  <ul class="links">
    <li><a href="/" class:list={[{ active: isActive('/') && path === '/' }]}>Accueil</a></li>
    <li><a href="/convert" class:list={[{ active: isActive('/convert') }]}>Convertir</a></li>
    <li><a href="/formats" class:list={[{ active: isActive('/formats') }]}>Formats</a></li>
    <li><a href="/download" class:list={[{ active: isActive('/download') }]}>Télécharger</a></li>
    <li><a href="/about" class:list={[{ active: isActive('/about') }]}>À propos</a></li>
  </ul>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--cal-border);
    background: var(--cal-surface);
  }

  .brand {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--cal-text);
    text-decoration: none;
  }

  .brand:hover {
    text-decoration: none;
    color: var(--cal-accent);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .links a {
    font-size: 0.875rem;
    color: var(--cal-text-muted);
    text-decoration: none;
  }

  .links a:hover,
  .links a.active {
    color: var(--cal-accent);
    text-decoration: none;
  }
</style>
