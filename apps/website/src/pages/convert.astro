---
import { ConvertShell } from '@convertalllocal/ui';
import Nav from '../components/Nav.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Convertir - ConvertAllLocal" description="Convertisseur local dans le navigateur, mêmes outils avec les limites techniques du navigateur.">
  <Nav />
  <main class="page">
    <header class="header">
      <h1>Convertir</h1>
      <p>
        Même interface que l'application. Traitement local, aucun upload serveur.
        Le moteur de conversion arrive prochainement.
      </p>
    </header>
    <ConvertShell client:load environment="browser" />
  </main>
</Layout>

<style>
  .page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 4rem;
  }

  .header {
    margin-bottom: 1.5rem;
  }

  .header h1 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .header p {
    margin: 0;
    color: var(--cal-text-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
</style>
