---
import './ConverterSettings.css';
---

<section class="converter-settings" data-converter-settings aria-labelledby="converter-settings-title">
  <h2 class="converter-settings__title" id="converter-settings-title">
    <i class="converter-settings__title-icon fa-solid fa-sliders" aria-hidden="true"></i>
    <span>Paramètres locaux</span>
  </h2>
  <p class="converter-settings__lead">
    Ces réglages sont enregistrés uniquement dans le stockage local de votre navigateur. Aucune
    donnée n'est envoyée sur un serveur. Les formats par défaut s'appliquent aux nouveaux fichiers
    ajoutés et aux fichiers encore en attente dans la file.
  </p>

  <div class="converter-settings__table-wrap">
    <table class="converter-settings__table">
      <colgroup>
        <col class="converter-settings__col-param" />
        <col class="converter-settings__col-desc" />
        <col class="converter-settings__col-action" />
      </colgroup>
      <thead>
        <tr>
          <th scope="col">Paramètre</th>
          <th scope="col">Description</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        <tr class="converter-settings__row-format">
          <th scope="row">Image</th>
          <td>
            <span class="converter-settings__field-hint">Tous les formats image web + PDF</span>
          </td>
          <td class="converter-settings__action-cell">
            <div class="converter-settings__action-slot">
              <div data-settings-output-picker="image"></div>
              <button
                type="button"
                class="converter-settings__btn"
                data-settings-reset-output="image"
                aria-label="Réinitialiser le format image par défaut"
              >
                Réinitialiser
              </button>
            </div>
          </td>
        </tr>
        <tr class="converter-settings__row-format">
          <th scope="row">Audio</th>
          <td>
            <span class="converter-settings__field-hint">WAV, MP3 ou OGG (toutes entrées audio web)</span>
          </td>
          <td class="converter-settings__action-cell">
            <div class="converter-settings__action-slot">
              <div data-settings-output-picker="audio"></div>
              <button
                type="button"
                class="converter-settings__btn"
                data-settings-reset-output="audio"
                aria-label="Réinitialiser le format audio par défaut"
              >
                Réinitialiser
              </button>
            </div>
          </td>
        </tr>
        <tr class="converter-settings__row-format">
          <th scope="row">Document</th>
          <td>
            <span class="converter-settings__field-hint">HTML, texte, JSON, CSV ou PDF (selon l'entrée)</span>
          </td>
          <td class="converter-settings__action-cell">
            <div class="converter-settings__action-slot">
              <div data-settings-output-picker="document"></div>
              <button
                type="button"
                class="converter-settings__btn"
                data-settings-reset-output="document"
                aria-label="Réinitialiser le format document par défaut"
              >
                Réinitialiser
              </button>
            </div>
          </td>
        </tr>
        <tr>
          <th scope="row">Mémoire</th>
          <td>
            <p class="converter-settings__storage-desc" data-settings-storage-status aria-live="polite">
              Rien d'enregistré
            </p>
          </td>
          <td class="converter-settings__action-cell">
            <div class="converter-settings__action-slot">
              <button
                type="button"
                class="converter-settings__btn"
                data-settings-clear-storage
                aria-label="Effacer toutes les données mémorisées par ConvertAllLocal sur cet appareil"
              >
                Tout effacer
              </button>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  import { initConverterSettings } from './converter-settings-ui.ts';

  void initConverterSettings();
  document.addEventListener('astro:page-load', () => {
    void initConverterSettings();
  });
</script>
