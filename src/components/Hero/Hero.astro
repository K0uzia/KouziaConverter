---
import './Hero.css';
---

<section class="hero" id="convertir" aria-labelledby="hero-title">
  <div class="hero__container">
    <div class="hero__content">
      <h1 class="hero__title" id="hero-title">
        La conversion de fichiers, enfin
        <strong class="hero__title-accent">rapide, gratuite et privée</strong>
      </h1>

      <p class="hero__lead">
        Images, vidéos et icônes : obtenez le bon format en quelques secondes, sans upload ni
        compte. Vos fichiers restent sur votre machine, open source et sans limite cachée.
      </p>

      <div class="hero__actions">
        <a href="#convertir" class="hero__btn hero__btn--primary">Convertir maintenant</a>
        <a href="#formats" class="hero__btn hero__btn--secondary">Voir les formats</a>
      </div>
    </div>
  </div>
</section>
