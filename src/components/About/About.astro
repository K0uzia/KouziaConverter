---
import './About.css';
import { aboutFaqItems } from '../../data/about-faq.ts';
import { brandName } from '../../data/site';
---

<section class="about" id="apropos" aria-labelledby="about-title">
  <div class="about__container">
    <header class="about__head">
      <h2 class="about__title" id="about-title">
        <i class="section-heading__icon fa-solid fa-lightbulb" aria-hidden="true"></i>
        <span>Pourquoi {brandName} ?</span>
      </h2>
      <p class="about__intro">
        Beaucoup de convertisseurs en ligne limitent l'accès, dégradent la qualité ou récupèrent vos
        fichiers. {brandName} est <strong>gratuit à vie</strong> et conçu pour convertir
        <strong>localement</strong>, sans abonnement, publicité ni frais cachés.
      </p>
    </header>

    <div class="about__points" role="list">
      <article class="about__point" role="listitem">
        <div class="about__point-grid">
          <span class="about__point-num" aria-hidden="true">1</span>
          <h3 class="about__point-title">Sans téléversement</h3>
          <p class="about__point-text">
            Pas d'envoi vers un serveur : vos fichiers restent sur <strong>votre machine</strong> pendant
            toute la conversion.
          </p>
        </div>
      </article>

      <article class="about__point" role="listitem">
        <div class="about__point-grid">
          <span class="about__point-num" aria-hidden="true">2</span>
          <h3 class="about__point-title">Dans le navigateur</h3>
          <p class="about__point-text">
            Images, audio, documents et PDF via <strong>WebAssembly</strong>, directement dans le
            navigateur, <strong>sans compte</strong>.
          </p>
        </div>
      </article>

      <article class="about__point" role="listitem">
        <div class="about__point-grid">
          <span class="about__point-num" aria-hidden="true">3</span>
          <h3 class="about__point-title">Application desktop</h3>
          <p class="about__point-text">
            Vidéo, Office lourd, RAW et gros fichiers : l'<strong>application locale</strong> reprend la
            même logique, toujours sans copie de vos données ailleurs.
          </p>
        </div>
      </article>
    </div>

    <section class="about__faq" aria-labelledby="about-faq-title">
      <h3 class="about__faq-title" id="about-faq-title">Questions fréquentes</h3>
      <div class="about__faq-list">
        {
          aboutFaqItems.map((item) => (
            <details class="about__faq-item" id={`about-faq-${item.id}`}>
              <summary class="about__faq-question">{item.question}</summary>
              <div class="about__faq-answer">
                {item.intro ? <p class="about__faq-intro">{item.intro}</p> : null}
                {item.bullets ? (
                  <ul class="about__faq-bullets">
                    {item.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                ) : null}
                {item.answer ? <p class="about__faq-text">{item.answer}</p> : null}
              </div>
            </details>
          ))
        }
      </div>
    </section>
  </div>
</section>

<script>
  import { initAboutFaq } from './about-faq.ts';

  initAboutFaq();
  document.addEventListener('astro:page-load', initAboutFaq);
</script>
