---
import './Footer.css';
import { assetUrl, brandName, githubUrl, pageUrl } from '../../data/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__container">
    <aside class="footer__brand">
      <a href={pageUrl('/')} class="footer__logo" aria-label={`Accueil ${brandName}`}>
        <img
          class="footer__logo-icon"
          src={assetUrl('logo.svg')}
          alt=""
          width="128"
          height="128"
          decoding="async"
        />
        <span class="footer__logo-text">{brandName}</span>
      </a>
      <p class="footer__copy">© {year} {brandName}. Tous droits réservés.</p>
    </aside>

    <nav class="footer__nav" aria-label="Liens du pied de page">
      <a href={pageUrl('documentation/')} class="footer__text-link">
        Documentations
      </a>
      <a href={pageUrl('confidentialite/')} class="footer__text-link">Confidentialité</a>
      <button type="button" class="footer__text-link footer__text-link--button" data-consent-manage>
        Préférences cookies
      </button>
    </nav>
  </div>
</footer>
