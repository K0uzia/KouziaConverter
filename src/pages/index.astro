---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero/Hero.astro';
import HowItWorks from '../components/HowItWorks/HowItWorks.astro';
import Supports from '../components/Supports/Supports.astro';
import About from '../components/About/About.astro';
import { buildFaqPageJsonLd } from '../data/seo-jsonld.ts';
import { brandName, companyName, defaultDescription, homeSections, siteUrl } from '../data/site';
import '../styles/pages/index.css';

const pageTitle = `${brandName} - ${companyName}`;
const faqJsonLd = buildFaqPageJsonLd(new URL(homeSections.apropos, siteUrl).href);
---

<Layout title={pageTitle} description={defaultDescription} canonicalPath="/">
  <meta
    slot="head"
    name="google-site-verification"
    content="pbrKK0uc6G0__OdrrqtVxwbYVrdC1SOp_aG7HwSw-lE"
  />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqJsonLd)} />
  <div slot="site-header" hidden aria-hidden="true"></div>
  <Hero />
  <HowItWorks />
  <Supports />
  <About />
</Layout>
