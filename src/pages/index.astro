---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero/Hero.astro';
import HowItWorks from '../components/HowItWorks/HowItWorks.astro';
import Supports from '../components/Supports/Supports.astro';
import About from '../components/About/About.astro';
import { brandName, defaultDescription } from '../data/site';
import '../styles/pages/index.css';

const pageTitle = `${brandName} - Kouzia`;
---

<Layout title={pageTitle} description={defaultDescription} canonicalPath="/">
  <Hero />
  <HowItWorks />
  <Supports />
  <About />
</Layout>
