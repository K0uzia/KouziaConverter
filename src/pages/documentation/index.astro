---
import DocsShell from '../../components/Docs/DocsShell.astro';
import Layout from '../../layouts/Layout.astro';
import '../../styles/pages/documentation.css';
import { articlesForCategory, docCategories } from '../../data/documentation';
import { brandName, pageUrl } from '../../data/site';
---

<Layout
  layout="docs"
  title={`Documentation - ${brandName}`}
  description={`Documentation ${brandName} : convertisseur web et application desktop, formats, limites et périmètre.`}
  canonicalPath="/documentation/"
>
  <DocsShell>
    <header class="docs__head">
      <h1 class="docs__title">Documentation</h1>
      <p class="docs__lead">
        Guides techniques pour le convertisseur {brandName} : formats pris en charge, limites du
        navigateur et périmètre de l'application desktop. Tout le traitement reste local, sans envoi
        de fichiers sur un serveur.
      </p>
      <p class="docs__lead">
        Commencez par <a href={pageUrl('documentation/web/conversions/')}>Conversions navigateur</a>{' '}
        si vous utilisez <a href={pageUrl('convertir/')}>la page Convertir</a>.
      </p>
    </header>

    <div class="docs__index">
      {
        docCategories.map((category) => (
          <section
            class:list={['docs__index-group', `docs__index-group--${category.id}`]}
            aria-labelledby={`docs-index-${category.id}`}
          >
            <h2 class="docs__index-cat" id={`docs-index-${category.id}`}>
              <i class={category.icon} aria-hidden="true"></i>
              <span>{category.title}</span>
            </h2>
            <p class="docs__index-desc">{category.description}</p>
            <ul class="docs__index-list">
              {articlesForCategory(category.id).map((article) => (
                <li class="docs__index-item">
                  <a class="docs__index-link" href={article.href}>
                    <span class="docs__index-link-title">{article.title}</span>
                    <span class="docs__index-link-desc">{article.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </DocsShell>
</Layout>
