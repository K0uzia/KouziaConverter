---
import '../styles/global.css';
import '../styles/layouts/Layout.css';
import Header from '../components/Header/Header.astro';
import Footer from '../components/Footer/Footer.astro';
import SiteGeoEdges from '../components/SiteGeo/SiteGeoEdges.astro';
import ConsentBanner from '../components/ConsentBanner/ConsentBanner.astro';
import { assetUrl, brandName, defaultDescription, googleAnalyticsId, analyticsConsentStorageKey, siteUrl } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  noindex?: boolean;
  layout?: 'default' | 'docs';
}

const {
  title = brandName,
  description = defaultDescription,
  ogImage = assetUrl('logo.svg'),
  canonicalPath,
  noindex = false,
  layout = 'default',
} = Astro.props;

const canonicalUrl = canonicalPath
  ? new URL(canonicalPath, siteUrl).href
  : new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="fr" class:list={[{ 'layout--docs': layout === 'docs' }]}>
  <head>
    <meta charset="utf-8" />
    <!-- Google tag (gtag.js) + mode Consentement -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
    <script is:inline define:vars={{ googleAnalyticsId, analyticsConsentStorageKey }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });

      try {
        var storedConsent = localStorage.getItem(analyticsConsentStorageKey);
        if (storedConsent === 'granted' || storedConsent === 'denied') {
          gtag('consent', 'update', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: storedConsent,
          });
        }
      } catch {
        /* localStorage indisponible */
      }

      gtag('js', new Date());
      gtag('config', googleAnalyticsId);
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Elms+Sans:ital,wght@0,100..900;1,100..900&family=Mallanna&family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href={assetUrl('favicon/favicon.svg')} />
    <link rel="apple-touch-icon" href={assetUrl('favicon/favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="" id="site-theme-color" />
    {noindex && <meta name="robots" content="noindex" />}
    {!noindex && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="manifest" href={assetUrl('manifest.webmanifest')} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var meta = document.getElementById('site-theme-color');
        if (!meta) return;
        var bg = getComputedStyle(document.documentElement).getPropertyValue('--color-bg').trim();
        if (bg) meta.setAttribute('content', bg);
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <SiteGeoEdges />
    <slot name="site-header">
      <Header />
    </slot>
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
  </body>
</html>
