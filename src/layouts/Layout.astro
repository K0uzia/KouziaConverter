---
import '../styles/global.css';
import '../styles/layouts/Layout.css';
import Header from '../components/Header/Header.astro';
import Footer from '../components/Footer/Footer.astro';
import { assetUrl, brandName, defaultDescription, siteUrl } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  title = brandName,
  description = defaultDescription,
  ogImage = assetUrl('logo.svg'),
  canonicalPath,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonicalPath
  ? new URL(canonicalPath, siteUrl).href
  : new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const grainUrl = assetUrl('grain.svg');
const grainFiberUrl = assetUrl('grain-fiber.svg');
const noiseStyle = `--page-noise-image: url('${grainUrl}'); --page-noise-fiber-image: url('${grainFiberUrl}');`;
---

<!doctype html>
<html lang="fr" style={noiseStyle}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={assetUrl('favicon/favicon.svg')} />
    <link rel="apple-touch-icon" href={assetUrl('favicon/favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#14171c" />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="manifest" href={assetUrl('manifest.webmanifest')} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Aller au contenu</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
